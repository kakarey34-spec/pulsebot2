# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application ID (same as bot user ID for most bots)
CLIENT_ID=your_application_id

# Optional: register slash commands to one guild instantly (recommended while testing)
GUILD_ID=your_server_id

# HTTP port for Render health checks (Render sets PORT automatically)
PORT=3000
